---
import BaseLayout from '../layouts/BaseLayout.astro';

// Peer-reviewed journal publications only (extracted from cv.typ)
const publications = [
  {
    year: 2025,
    authors: "Chauvette, L., Grenier, A.S., Albouy, P., Coffey, E., Zatorre, R., & Sharp, A.",
    title: "Auditory and vibrotactile interactions in perception of timbre acoustic features.",
    journal: "Scientific reports",
    volume: "15(1)",
    pages: "38055",
    doi: "10.1038/s41598-025-21908-4",
  },
  {
    year: 2025,
    authors: "Hotton, M., Chauvette, L., Poulin, S., & Gagné, J. P.",
    title: "Investigating the implementation of a new protocol and clinical tool designed to assess the audiological needs of individuals with hearing loss in primary care settings.",
    journal: "Frontiers in Audiology and Otology",
    volume: "2",
    pages: "1520014",
    doi: "10.3389/fauot.2024.1520014",
  },
  {
    year: 2025,
    authors: "Chauvette, L., Whittom, A., Fecteau, A., Larouche-Gagnon, G., & Sharp, A.",
    title: "Musicianship Modulates Octave Illusion Perception Differently Across Stimulation Frequencies.",
    journal: "Psychological Research",
    volume: "88(78)",
    pages: "1-13",
    doi: "10.1007/s00426-025-02112-5",
  },
  {
    year: 2024,
    authors: "Chauvette, L., Leprohon, É., Perron-Houle, L.-P., Pintat, V., Delnavaz, A., Voix, J. & Sharp, A.",
    title: "Multichannel Vibrotactile Glove: Validation of a new device designed to sense vibrations.",
    journal: "IEEE transactions on haptics",
    volume: "17(4)",
    pages: "913-923",
    doi: "10.1109/TOH.2024.3475740",
  },
  {
    year: 2024,
    authors: "Sharp, A., Carbajal Chavez, A. B., Chauvette, L., Zatorre, R., & Coffey, E.",
    title: "Feel sounds with your hands: Exploring tactile frequency-following response.",
    journal: "The Journal of the Acoustical Society of America",
    volume: "155(3 Suppl.)",
    pages: "A37–A37",
    doi: "10.1121/10.0026714",
  },
  {
    year: 2024,
    authors: "Whittom, A., Chauvette, L., Bégin, A., Blanchette, I., Tremblay, P., & Sharp, A.",
    title: "Music Perception in Older Adults With Hearing Loss: Protective Effect of Musical Experience.",
    journal: "Ear and hearing",
    volume: "46(3)",
    pages: "707–718",
    doi: "10.1097/AUD.0000000000001615",
  },
  {
    year: 2023,
    authors: "Chauvette, L., Pinsonnault-Skvarenina, A., Sharp, A., Gagné J.-P., Lacerda, A. B. M., & Hotton, M.",
    title: "Perceptions of Adults with Hearing Loss About the Communication Difficulties Generated by the COVID-19 Preventive Measures: A Qualitative Study.",
    journal: "Journal of Speech, Language, and Hearing Research",
    volume: "66(12)",
    pages: "5109–5128",
    doi: "10.1044/2023_JSLHR-23-00163",
  },
  {
    year: 2023,
    authors: "Hotton, M., Chauvette, L., & Gagné, J. P.",
    title: "Pilot evaluation of a protocol and a clinical tool developed to assess the audiological needs of adults with hearing loss.",
    journal: "International Journal of Audiology",
    volume: "63(10)",
    pages: "827–835",
    doi: "10.1080/14992027.2023.2211737",
  },
  {
    year: 2023,
    authors: "Whittom, A., Couture, F., Chauvette, L., & Sharp, A.",
    title: "Octave illusion: Stimulation frequencies can modulate perception.",
    journal: "Psychological Research",
    volume: "87",
    pages: "2183-2191",
    doi: "10.1007/s00426-023-01805-z",
  },
  {
    year: 2022,
    authors: "Chauvette, L., Fournier, P., & Sharp, A.",
    title: "The frequency-following response to assess the neural representation of spectral speech cues in older adults.",
    journal: "Hearing Research",
    volume: "418",
    pages: "108486",
    doi: "10.1016/j.heares.2022.108486",
  },
  {
    year: 2022,
    authors: "Pinsonnault-Skvarenina, A., Hotton, M., Sharp, A., Chauvette, L., Tremblay, É., Choquette, R., Ansaldo, A. I., Gagné, J. P., & Lacerda, A.",
    title: "Communication during the COVID-19 pandemic: the hearing-impaired perspective.",
    journal: "International journal of audiology",
    volume: "62(12)",
    pages: "1155–1165",
    doi: "10.1080/14992027.2022.2120552",
  },
];

// Helper function to bold "Chauvette, L." in author list
function formatAuthors(authors: string): string {
  return authors.replace(/Chauvette, L\./g, '<strong>Chauvette, L.</strong>');
}
---

<BaseLayout 
  title="Publications - Loonan Chauvette"
  description="Peer-reviewed publications by Loonan Chauvette on auditory-tactile perception, timbre processing, and hearing rehabilitation."
>
  <!-- Publications Header -->
  <section class="py-12 bg-surface-container-low border-b border-surface-container">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="font-serif text-display-md text-on-surface">
        Publications
      </h1>
    </div>
  </section>

  <!-- Publications List with Asymmetric Layout -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-3">
        <p class="font-sans text-label-md text-on-surface-variant uppercase tracking-wider sticky top-24">
          Peer-Reviewed<br />Articles
        </p>
      </div>

      <div class="md:col-span-9 space-y-12">
        {publications.map((pub) => (
          <article class="pb-8 border-b border-surface-container last:border-b-0">
            <!-- Year Label -->
            <p class="font-sans text-label-lg text-on-surface-variant uppercase mb-3">
              {pub.year}
            </p>

            <!-- Authors -->
            <p 
              class="font-sans text-body-lg text-on-surface mb-2" 
              set:html={formatAuthors(pub.authors)}
            />

            <!-- Title -->
            <h2 class="font-serif text-title-lg text-on-surface mb-2">
              {pub.title}
            </h2>

            <!-- Journal Info -->
            <p class="font-sans text-body-md text-on-surface-variant italic">
              {pub.journal}, <span class="not-italic">{pub.volume}</span>{pub.pages ? `, ${pub.pages}` : ''}.
            </p>

            <!-- DOI Link -->
            {pub.doi && (
              <p class="font-sans text-body-md text-on-surface-variant mt-2">
                DOI: <a 
                  href={`https://doi.org/${pub.doi}`} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="link-primary"
                >
                  {pub.doi}
                </a>
              </p>
            )}
          </article>
        ))}
      </div>
    </div>

    <!-- Note about Conference Presentations -->
    <div class="grid md:grid-cols-12 gap-8 mt-16 pt-16 border-t border-surface-container">
      <div class="md:col-span-3"></div>
      <div class="md:col-span-9">
        <div class="bg-surface-container-low p-8">
          <h3 class="font-serif text-title-lg text-on-surface mb-3">
            Conference Presentations
          </h3>
          <p class="font-sans text-body-lg text-on-surface leading-relaxed">
            In addition to these peer-reviewed publications, I have presented my research at numerous 
            international and national conferences through oral presentations and poster sessions. 
            For a complete list of conference contributions, please refer to my full 
            <a href="/cv" class="link-primary">curriculum vitae</a> or 
            <a href="/cv.pdf" download class="link-primary">download the PDF version</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
